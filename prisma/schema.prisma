model EgressRules {
  uuid              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  viewPosition      Int       @default(autoincrement()) @map("view_position")
  name              String    @map("name") @db.VarChar(128)
  description       String?   @map("description")
  pattern           String    @map("pattern")
  action            String    @map("action") @db.VarChar(32)
  isEnabled         Boolean   @default(true) @map("is_enabled")
  targetUsers       Json?     @map("target_users")
  proxyOutboundUuid String?   @map("proxy_outbound_uuid") @db.Uuid
  proxyGroupUuid    String?   @map("proxy_group_uuid") @db.Uuid
  validFrom         DateTime? @map("valid_from")
  expiresAt         DateTime? @map("expires_at")
  createdAt         DateTime  @default(dbgenerated("now()")) @map("created_at")
  updatedAt         DateTime  @default(dbgenerated("now()")) @updatedAt @map("updated_at")

